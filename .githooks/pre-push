#!/bin/bash
# Pre-push hook to validate branch naming conventions
# Install: git config core.hooksPath .githooks

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the current branch name
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)

# List of valid protected branches that can be pushed to
PROTECTED_BRANCHES=("main" "develop")

# Check if branch is protected (main/develop)
for protected in "${PROTECTED_BRANCHES[@]}"; do
  if [[ "$BRANCH_NAME" == "$protected" ]]; then
    echo -e "${RED}Error: You cannot push directly to the '$protected' branch.${NC}"
    echo "Please create a feature/bugfix/hotfix branch and submit a pull request."
    exit 1
  fi
done

# Valid branch patterns
VALID_PATTERNS=(
  '^feature/[a-z0-9-]+/[a-z0-9-]+$'           # feature/{module}/{description}
  '^bugfix/[a-z0-9-]+/[a-z0-9-]+$'            # bugfix/{module}/{description}
  '^hotfix/[a-z0-9-]+/[a-z0-9-]+$'            # hotfix/{module}/{description}
  '^release/v[0-9]+\.[0-9]+\.[0-9]+$'         # release/vX.Y.Z
  '^docs/[a-z0-9-]+$'                         # docs/{description}
  '^chore/[a-z0-9-]+$'                        # chore/{description}
)

# Check if branch matches any valid pattern
IS_VALID=false
for pattern in "${VALID_PATTERNS[@]}"; do
  if [[ $BRANCH_NAME =~ $pattern ]]; then
    IS_VALID=true
    break
  fi
done

if [[ "$IS_VALID" == false ]]; then
  echo -e "${RED}Error: Branch name '$BRANCH_NAME' does not follow naming conventions.${NC}"
  echo ""
  echo "Valid patterns:"
  echo "  feature/{module-name}/{description}    - New features or module changes"
  echo "  bugfix/{module-name|general}/{description} - Bug fixes"
  echo "  hotfix/{module-name|general}/{description} - Urgent production fixes"
  echo "  release/v{major}.{minor}.{patch}       - Release branches"
  echo "  docs/{description}                      - Documentation changes"
  echo "  chore/{description}                     - Maintenance/tooling changes"
  echo ""
  echo "Examples:"
  echo "  feature/azure-firewall/add-diagnostic-settings"
  echo "  bugfix/key-vault/fix-purge-protection-policy"
  echo "  hotfix/general/critical-security-patch"
  echo "  release/v1.2.3"
  echo ""
  exit 1
fi

echo -e "${GREEN}✓ Branch name '$BRANCH_NAME' is valid${NC}"
exit 0
